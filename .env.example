# Local mode (Docker)
VL_MODEL_NAME=Qwen/Qwen3-VL-4B-Instruct
IMAGE_NAME=lmcache/vllm-openai:v0.3.14

# Remote mode
MODEL_NAME=your-model-name
VLLM_BASE_URL=https://your-server.example.com/endpoint
VLLM_API_KEY=sk-your-api-key
VLLM_TOKENIZER=org/tokenizer-name
VLLM_TOKENIZER_MODE=                                     # Mistral 모델: mistral

# GPU config (saved as metadata in results)
GPU_NAME=RTX-5090
GPU_MEM_UTIL=0.85
MAX_MODEL_LEN=131072
MAX_BATCHED_TOKENS=65536
MAX_NUM_SEQS=256
REPLICA=1
QUANT_OPT=FP8
